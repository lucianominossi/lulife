# Database — Neon Postgres connection string
# Leave empty to use local PGlite (.data/)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Public app URL (used in confirmation / reset emails)
# AUTH_URL=http://localhost:3000
# AUTH_URL=https://your-app.vercel.app

# Email (Brevo) — optional for MVP
# Without BREVO_API_KEY, verification/reset links go to server logs (Vercel Runtime Logs).
# Changing email without Brevo auto-verifies so you are not locked out.
# Verify a sender in Brevo (Settings → Senders) — no custom domain required for MVP.
# BREVO_API_KEY=xkeysib-xxxxx
# EMAIL_FROM="Lulife <seu-email-verificado@gmail.com>"

# Initial user for seed script (created already verified)
SEED_EMAIL=you@example.com
SEED_PASSWORD=change-me
SEED_NAME=You

# Protect /api/cron/recurring
CRON_SECRET=
