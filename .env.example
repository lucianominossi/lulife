# Database — Neon Postgres connection string
# Leave empty to use local PGlite (.data/)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Supabase Auth (Dashboard → Project Settings → API)
# Create a free project at https://supabase.com
# Auth → URL Configuration:
#   Site URL: http://localhost:3000 (prod: https://your-app.vercel.app)
#   Redirect URLs: http://localhost:3000/auth/callback, https://your-app.vercel.app/auth/callback
# Auth → Email: enable Confirm email + templates (confirm / reset) as needed
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — server/scripts only (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Public app URL (used in auth email redirectTo)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Initial user for seed script (created in Supabase Auth + local mirror)
SEED_EMAIL=you@example.com
SEED_PASSWORD=change-me
SEED_NAME=You

# Protect /api/cron/recurring
CRON_SECRET=
