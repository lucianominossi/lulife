# Database — Neon Postgres connection string
# Leave empty to use local PGlite (.data/)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Supabase Auth (Dashboard → Project Settings → API)
# Create a free project at https://supabase.com
#
# Security checklist (Auth dashboard):
# - URL Configuration → Site URL = production app URL
# - Redirect URLs allowlist: https://your-app.vercel.app/auth/callback
#   (+ http://localhost:3000/auth/callback for local)
# - Email: Confirm email ENABLED
# - Password: min length ≥ 10 (match app rules: letter + number)
# - Enable Auth rate limiting / bot protection if available
# - Never put SUPABASE_SERVICE_ROLE_KEY in NEXT_PUBLIC_* or client bundles
# - Optional: enable MFA for high-risk accounts
#
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — server/scripts only (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Public app URL (auth email redirectTo + Server Actions allowedOrigins)
# Required in production. Prefer this over relying on VERCEL_URL alone.
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Initial user for seed script (created in Supabase Auth + local mirror)
# Use a strong password; never reuse the placeholder in production.
SEED_EMAIL=you@example.com
SEED_PASSWORD=change-me-to-a-strong-password
SEED_NAME=You

# Protect /api/cron/recurring (Bearer token; required in production)
CRON_SECRET=
